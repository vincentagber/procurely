  "faqs": [
    {
      "question": "How long does BOQ processing take?",
      "answer": "Most BOQs are reviewed within 4 business hours, with a confirmed matched quote sent the same day for standard orders."
    },
    {
      "question": "What are the credit terms?",
      "answer": "Eligible projects can spread payments across four structured installments at 0% promotional interest, subject to KYC and project verification."
    },
    {
      "question": "Can Procurely handle phased deliveries?",
      "answer": "Yes. We support milestone-based scheduling so site teams receive the right material batches exactly when each construction phase is ready."
    }
  ],
