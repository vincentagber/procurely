# =========================
# APP CONFIG
# =========================
APP_DEBUG=false
FRONTEND_URL=https://useprocurely.com
TOKEN_TTL_DAYS=30

# =========================
# DATABASE CONFIG
# =========================
DB_DRIVER=sqlite
DATABASE_PATH=storage/procurely.sqlite

# Production MySQL (uncomment for production)
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=your_database_name
# DB_USER=your_database_user
# DB_PASS=your_secure_password

# =========================
# SMTP CONFIG
# =========================
# SMTP_HOST=your_smtp_host
# SMTP_PORT=465
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password

# =========================
# PAYMENT CONFIG (PAYSTACK)
# =========================
# PAYSTACK_PUBLIC_KEY=pk_test_your_test_key
# PAYSTACK_SECRET_KEY=sk_test_your_test_secret_key
